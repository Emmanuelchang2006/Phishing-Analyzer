# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Phishing Analyzer"
APP_VERSION="1.0.0"
ENVIRONMENT="development"        # development | staging | production
DEBUG=true
SECRET_KEY="change-me-to-a-long-random-string-in-production"

# ── Server ────────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/phishing_analyzer"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL_SECONDS=3600           # Default cache expiry: 1 hour

# ── Threat Intelligence APIs ──────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=""            # https://www.virustotal.com/gui/my-apikey
ABUSEIPDB_API_KEY=""             # https://www.abuseipdb.com/account/api

# ── AI Verdict (Gemini API) ───────────────────────────────────────────────────
GEMINI_API_KEY=""                # https://aistudio.google.com/app/apikey (free)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="console"             # console (development) | json (production)
